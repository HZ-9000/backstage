# Copy this file to .env and fill in your secrets.
# .env is gitignored and will be injected into the devcontainer environment.

# GitHub Personal Access Token — used by the GitHub integration and scaffolder
# https://backstage.io/docs/integrations/github/locations#configuration
GITHUB_TOKEN=

# Shared secret for backend service-to-service auth
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
BACKEND_SECRET=
